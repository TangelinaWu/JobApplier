{
  "manifest_version": 2,
  "name": "JobApplier",
  "version": "1.0.0",
  "description": "Automatically fills job application forms using your saved profile.",
  "author": "Angelina",

  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "https://api.anthropic.com/*"
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png"
    }
  },

  "background": {
    "scripts": ["background/background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": [
        "*://www.linkedin.com/jobs/*",
        "*://linkedin.com/jobs/*"
      ],
      "js": [
        "shared/profileSchema.js",
        "shared/messaging.js",
        "content/core/humanDelay.js",
        "content/core/formFiller.js",
        "content/core/overlay.js",
        "content/core/floatingButton.js",
        "content/core/detector.js",
        "content/sites/linkedin.js",
        "content/main.js"
      ],
      "css": ["assets/styles/button.css", "assets/styles/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://app.joinhandshake.com/*"
      ],
      "js": [
        "shared/profileSchema.js",
        "shared/messaging.js",
        "content/core/humanDelay.js",
        "content/core/formFiller.js",
        "content/core/overlay.js",
        "content/core/floatingButton.js",
        "content/core/detector.js",
        "content/sites/handshake.js",
        "content/main.js"
      ],
      "css": ["assets/styles/button.css", "assets/styles/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://jobs.lever.co/*",
        "*://*.lever.co/*"
      ],
      "js": [
        "shared/profileSchema.js",
        "shared/messaging.js",
        "content/core/humanDelay.js",
        "content/core/formFiller.js",
        "content/core/overlay.js",
        "content/core/floatingButton.js",
        "content/core/detector.js",
        "content/sites/lever.js",
        "content/main.js"
      ],
      "css": ["assets/styles/button.css", "assets/styles/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://boards.greenhouse.io/*",
        "*://job-boards.greenhouse.io/*",
        "*://*.greenhouse.io/*"
      ],
      "js": [
        "shared/profileSchema.js",
        "shared/messaging.js",
        "content/core/humanDelay.js",
        "content/core/formFiller.js",
        "content/core/overlay.js",
        "content/core/floatingButton.js",
        "content/core/detector.js",
        "content/sites/greenhouse.js",
        "content/main.js"
      ],
      "css": ["assets/styles/button.css", "assets/styles/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.myworkdayjobs.com/*"
      ],
      "js": [
        "shared/profileSchema.js",
        "shared/messaging.js",
        "content/core/humanDelay.js",
        "content/core/formFiller.js",
        "content/core/overlay.js",
        "content/core/floatingButton.js",
        "content/core/detector.js",
        "content/sites/workday.js",
        "content/main.js"
      ],
      "css": ["assets/styles/button.css", "assets/styles/overlay.css"],
      "run_at": "document_idle"
    }
  ],

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "jobapplier@angelina.getlea.io",
      "strict_min_version": "109.0"
    }
  }
}
